# Copiar a .env / configurar en Amplify (no commitear secretos reales aquí).
# El Measurement ID de GA4 es público; sí puede ir en el bundle web.

EXPO_PUBLIC_SITE_URL=https://mealcanza.cl
SITE_URL=https://mealcanza.cl

# Google Analytics 4 (solo se carga en web)
EXPO_PUBLIC_GA_MEASUREMENT_ID=G-FT4PQW3ZYW

# Opcional (desarrollo)
# EXPO_PUBLIC_GA_DEBUG=true
# EXPO_PUBLIC_GA_ALLOW_LOCALHOST=true

# Opcional Search Console
